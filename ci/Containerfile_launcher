FROM ubuntu:24.04

# Warning nuitka x86 doesn't have this issue but if you're using the
# x64 version the depends.exe will give an error like mfc42.dll failed to import.
# and it's not fixable by running winetricks -q mfc42
# If you gotta compile for x64 you gotta put the working depends to the cache folder by doing
# mkdir -p $WINEPREFIX/prefix/drive_c/users/$USER/AppData/Local/Nuitka/Nuitka/Cache/downloads/depends/x86_64
# wget -O /build/depends22_x86.zip https://dependencywalker.com/depends22_x86.zip
# unzip /build/depends22_x86.zip -d /build/wine/prefix/drive_c/users/$USER/AppData/Local/Nuitka/Nuitka/Cache/downloads/depends/x86_64

ENV DEBIAN_FRONTEND=noninteractive
ENV PROTON_ENABLE_WAYLAND=1
ENV WINEPREFIX=/build/wine/prefix
ENV WINEDEBUG=fixme-all
ENV WINEDLLOVERRIDES="winemenubuilder.exe=d"
ENV XDG_RUNTIME_DIR=/build/xdg
ENV WLR_RENDERER=pixman

# ---- Dependencies ----
RUN dpkg --add-architecture i386 && \
    apt-get update && apt-get install -y \
        sudo curl wget gnupg2 ca-certificates tar xz-utils unzip \
        cage xwayland-run \
        winbind lib32gcc-s1 lib32stdc++6 libc6-i386 \
    && rm -rf /var/lib/apt/lists/*

# ---- WineHQ ----
RUN mkdir -pm755 /etc/apt/keyrings && \
    curl -fsSL https://dl.winehq.org/wine-builds/winehq.key \
        -o /etc/apt/keyrings/winehq-archive.key && \
    curl -fsSL https://dl.winehq.org/wine-builds/ubuntu/dists/noble/winehq-noble.sources \
        -o /etc/apt/sources.list.d/winehq-noble.sources && \
    apt-get update && \
    apt-get install -y --install-recommends winehq-devel && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /build

COPY . .

# ---- Create prefix headlessly, set Wayland driver ----
RUN mkdir -p $WINEPREFIX $XDG_RUNTIME_DIR && \
    wineboot -u 2>/dev/null; \
    wineserver -w; \
    wine reg add "HKEY_CURRENT_USER\\Software\\Wine\\Drivers" \
        /v Graphics /t REG_SZ /d wayland /f 2>/dev/null; \
    wineserver -w; \
    echo "PREFIX READY"

# ---- Install Python + deps under cage (Wine uses Wayland driver) ----
RUN wget -q https://www.python.org/ftp/python/3.12.9/python-3.12.9.exe && \
    wlheadless-run -c cage -- \
    wine python-3.12.9.exe /quiet \
        InstallAllUsers=0 \
        Include_launcher=0 \
        Include_test=0 \
        Include_symbols=0 \
        Include_tcltk=1 \
        PrependPath=1 \
        TargetDir=C:\\Python312 && \
    rm -f python-3.12.9.exe && \
    wineserver -w && \
    echo "PYTHON INSTALLED"

RUN wlheadless-run -c cage -- \
    wine C:\\Python312\\python.exe -m pip install --no-python-version-warning \
        --disable-pip-version-check \
        nuitka zstandard ordered-set -r requirements.txt && \
    wineserver -w && \
    echo "PACKAGES INSTALLED"

# ---- Build Windows binary with Nuitka under cage ----
RUN wlheadless-run -c cage -- \
    wine C:\\Python312\\python.exe -m nuitka \
        --mingw64 \
        --assume-yes-for-downloads \
        --enable-plugin=tk-inter \
        --onefile \
        /build/OutlastTogether.py \
        --output-filename=/build/OutlastLauncher.exe && \
    echo "BUILD SUCCESS"
